{
  "rules": {
     "waitlist": {
      ".read": false,
      ".write": true,
      "$entry": {
        ".validate": "newData.hasChildren(['email', 'timestamp']) && newData.child('email').isString() && newData.child('email').val().matches(/^[^@]+@[^@]+\\.[^@]+$/)"
      }
    },
    "buses": {
      ".read": true,
      "$busId": {
        ".write": "auth != null && (auth.uid === $busId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "currentLocation": {
          ".validate": "newData.hasChildren(['lat', 'lng', 'timestamp'])"
        }
      }
    },
    "locations": {
      ".read": false,
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "drivers": {
      "active": {
        ".read": true,
        "$driverId": {
          ".write": "auth != null && (auth.uid === $driverId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
        }
      }
    },
    "bookings": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["busId", "passengerId"]
    },
    "tripRequests": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$busId": {
        ".indexOn": ["createdAt", "status"]
      }
    },
    "trips": {
      ".write": "auth != null",
      "$tripId": {
        ".read": "auth != null && (data.child('passengerId').val() === auth.uid || data.child('driverId').val() === auth.uid)",
        ".indexOn": ["driverId", "passengerId", "status", "createdAt"]
      }
    },
    "tripLocations": {
      "$tripId": {
        ".read": "auth != null && (root.child('trips').child($tripId).child('passengerId').val() === auth.uid || root.child('trips').child($tripId).child('driverId').val() === auth.uid)",
        "driver": {
          ".write": "auth != null && root.child('trips').child($tripId).child('driverId').val() === auth.uid"
        },
        "passenger": {
          ".write": "auth != null && root.child('trips').child($tripId).child('passengerId').val() === auth.uid"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        "verificationBadge": {
           ".validate": "newData.hasChildren(['mintAddress', 'txSignature'])"
        }
      }
    },
    "alerts": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
